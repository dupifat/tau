// Built-in extensions shipped with tau. argv = prefix ++ command ++ suffix.
// When `command` is omitted, `builtin_extensions()` fills it with the
// running tau binary, so each built-in only needs to specify the
// component subcommand in `suffix`.
[
    {
        name: "provider-builtin",
        suffix: ["component", "ext-provider-builtin"],
        role: "provider",
        enable: true,
        config: {},
    },
    {
        name: "core-shell",
        suffix: ["component", "ext-shell"],
        role: "tool",
        enable: true,
        config: {},
    },
    {
        name: "test-dummy",
        suffix: ["component", "ext-test-dummy"],
        role: "tool",
        enable: false,
        config: {},
    },
    {
        name: "std-rhai",
        suffix: ["component", "ext-rhai"],
        role: "tool",
        enable: false,
        config: {},
    },
    {
        name: "std-notifications",
        suffix: ["component", "ext-std-notifications"],
        role: "tool",
        enable: true,
        config: { "agent_start": [], "agent_end": [], "agent_idle": [], "agent_idle_all": [] },
    },
    {
        name: "std-telegram",
        suffix: ["component", "ext-telegram"],
        role: "tool",
        enable: false,
        config: {},
    },
    {
        name: "std-websearch",
        suffix: ["component", "ext-websearch"],
        role: "tool",
        enable: true,
        config: {},
    },
    {
        name: "std-pim",
        suffix: ["component", "ext-pim"],
        role: "tool",
        enable: false,
        config: {},
    },
    {
        name: "std-email",
        suffix: ["component", "ext-pim"],
        role: "tool",
        enable: false,
        config: {},
    },
]
